@model Platform.Portal.Models.ViewModels.UserPermissionsViewModel
@{
    ViewData["Title"] = "Modifica Permessi Utente";
}

<style>
    .permission-toggle-card {
        transition: all 0.2s ease-in-out;
    }

    .permission-toggle-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-sm);
    }

    .permission-toggle-card .form-check-input {
        width: 2.5em;
        height: 1.25em;
    }
</style>

<!-- Info Utente -->
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3">
            <div class="user-avatar-table" style="width: 60px; height: 60px; font-size: 2rem;">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>
            <div>
                <h4 class="mb-0">@Model.FullName</h4>
                <p class="mb-1 text-muted">@@@Model.Username</p>
                <span class="badge bg-secondary rounded-pill">@Model.Role</span>
            </div>
        </div>
    </div>
</div>

<!-- Form Permessi -->
<form asp-action="EditUser" method="post" id="permissionsForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="Username" />
    <input type="hidden" asp-for="FullName" />
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Role" />

    @for (int i = 0; i < Model.Applications.Count; i++)
    {
        var app = Model.Applications[i];
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <span class="material-icons align-middle me-2 text-primary">@app.Icon</span>
                    @app.DisplayName
                </h5>
                <div class="form-check form-switch">
                    <input class="form-check-input all-permissions-toggle" type="checkbox" id="all_@i" onchange="toggleAllPermissions(@i, this.checked)" @(app.CanView && app.CanCreate && app.CanEdit && app.CanDelete ? "checked" : "")>
                    <label class="form-check-label" for="all_@i">Tutti i permessi</label>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <!-- View -->
                    <div class="col-md-6 col-lg-3">
                        <div class="card permission-toggle-card h-100">
                            <div class="card-body text-center">
                                <span class="material-icons fs-1 text-success">visibility</span>
                                <h6 class="mt-2">Visualizzazione</h6>
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input permission-checkbox" type="checkbox" asp-for="Applications[i].CanView" data-group="@i">
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Create -->
                    <div class="col-md-6 col-lg-3">
                        <div class="card permission-toggle-card h-100">
                            <div class="card-body text-center">
                                <span class="material-icons fs-1 text-primary">add_circle</span>
                                <h6 class="mt-2">Creazione</h6>
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input permission-checkbox" type="checkbox" asp-for="Applications[i].CanCreate" data-group="@i">
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Edit -->
                    <div class="col-md-6 col-lg-3">
                        <div class="card permission-toggle-card h-100">
                            <div class="card-body text-center">
                                <span class="material-icons fs-1 text-warning">edit</span>
                                <h6 class="mt-2">Modifica</h6>
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input permission-checkbox" type="checkbox" asp-for="Applications[i].CanEdit" data-group="@i">
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Delete -->
                    <div class="col-md-6 col-lg-3">
                        <div class="card permission-toggle-card h-100">
                            <div class="card-body text-center">
                                <span class="material-icons fs-1 text-danger">delete</span>
                                <h6 class="mt-2">Eliminazione</h6>
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input permission-checkbox" type="checkbox" asp-for="Applications[i].CanDelete" data-group="@i">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Form Actions -->
    <div class="card">
        <div class="card-body p-3">
            <div class="d-flex justify-content-end gap-2">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <span class="material-icons align-middle">close</span>
                    Annulla
                </a>
                <button type="button" class="btn btn-outline-danger" onclick="resetAllPermissions()">
                    <span class="material-icons align-middle">delete_sweep</span>
                    Rimuovi Tutti
                </button>
                <button type="submit" class="btn btn-primary">
                    <span class="material-icons align-middle">save</span>
                    Salva Permessi
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function toggleAllPermissions(groupIndex, checked) {
            const checkboxes = document.querySelectorAll(`input[data-group="${groupIndex}"]`);
            checkboxes.forEach(cb => {
                cb.checked = checked;
            });
        }

        function resetAllPermissions() {
            if (confirm('Sei sicuro di voler rimuovere tutti i permessi per questo utente?')) {
                document.querySelectorAll('.permission-checkbox, .all-permissions-toggle').forEach(cb => {
                    cb.checked = false;
                });
            }
        }
    </script>
}
