@model SetPasswordViewModel

@{
    ViewData["Title"] = "Imposta Password";
    Layout = "_Layout"; // Usa il layout principale, ma verrà mostrato come pagina di login
}

<div class="login-container">
    <div class="login-card">
        <div class="login-logo">
            <span class="material-icons">password</span>
        </div>
        <h3 class="login-title">Crea la tua Password</h3>
        <p class="login-subtitle">Benvenuto! Imposta la password per accedere alla piattaforma.</p>

        <form asp-action="SetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Token" />

            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Nuova Password" />
                <label asp-for="Password"></label>
                <span class="material-icons">vpn_key</span>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Conferma Nuova Password" />
                <label asp-for="ConfirmPassword"></label>
                <span class="material-icons">check_circle</span>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-videosystem btn-lg">
                    <span class="material-icons align-middle">login</span>
                    Imposta Password e Accedi
                </button>
            </div>
        </form>
    </div>
</div>
