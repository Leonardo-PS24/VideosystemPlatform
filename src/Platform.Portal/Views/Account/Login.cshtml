@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="text-center mb-4">
    <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-3" style="width: 64px; height: 64px;">
        <span class="material-icons" style="font-size: 32px;">layers</span>
    </div>
    <h2 class="fw-bold text-primary">Videosystem</h2>
    <p class="text-secondary">Accedi alla piattaforma aziendale</p>
</div>

<form asp-action="Login" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

    <div class="mb-3">
        <label asp-for="Username" class="form-label fw-bold text-secondary">Utente</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0">
                <span class="material-icons text-secondary" style="font-size: 20px;">person</span>
            </span>
            <input asp-for="Username" class="form-control border-start-0 ps-0" placeholder="Inserisci username" autofocus />
        </div>
        <span asp-validation-for="Username" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Password" class="form-label fw-bold text-secondary">Password</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0">
                <span class="material-icons text-secondary" style="font-size: 20px;">lock</span>
            </span>
            <input asp-for="Password" class="form-control border-start-0 ps-0" placeholder="Inserisci password" />
        </div>
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label text-secondary">Ricordami</label>
        </div>
        <a href="#" class="text-decoration-none small text-primary">Password dimenticata?</a>
    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary btn-lg">
            ACCEDI
        </button>
    </div>
</form>

<div class="text-center mt-4 pt-3 border-top">
    <small class="text-muted">© @DateTime.Now.Year Videosystem S.r.l.</small>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
