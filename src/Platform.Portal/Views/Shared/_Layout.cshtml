<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Videosystem Platform</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="wrapper">
        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-container">
                    <span class="material-icons logo-icon">layers</span>
                    <span class="logo-text">Videosystem</span>
                </div>
                <!-- Close button for mobile -->
                <button class="btn btn-link text-white d-lg-none ms-auto p-0" id="sidebarClose">
                    <span class="material-icons">close</span>
                </button>
            </div>

            <div class="sidebar-menu">
                <div class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" title="Dashboard">
                        <span class="nav-icon material-icons">dashboard</span>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="nav-item mt-4 mb-2">
                        <small class="text-uppercase text-white-50 px-3 nav-text" style="font-size: 0.7rem; font-weight: 700;">Amministrazione</small>
                    </div>
                    <div class="nav-item">
                        <a asp-controller="Admin" asp-action="Users" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")" title="Gestione Utenti">
                            <span class="nav-icon material-icons">people</span>
                            <span class="nav-text">Utenti</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a asp-controller="Permissions" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Permissions" ? "active" : "")" title="Gestione Permessi">
                            <span class="nav-icon material-icons">security</span>
                            <span class="nav-text">Permessi</span>
                        </a>
                    </div>
                }
            </div>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="user-avatar">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div class="user-info">
                        <span class="user-name">@User.Identity.Name</span>
                        <span class="user-role">@(User.IsInRole("Admin") ? "Amministratore" : "Utente")</span>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn-logout" title="Esci">
                        <span class="material-icons">logout</span>
                        <span class="logout-text">Esci</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <div class="header-left">
                    <button class="toggle-btn" id="sidebarToggle">
                        <span class="material-icons">menu</span>
                    </button>
                    <h1 class="page-title">@ViewData["Title"]</h1>
                </div>
                <div class="header-right">
                    @RenderSection("HeaderActions", required: false)
                </div>
            </header>

            <!-- Page Content -->
            <div class="content-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
                        <div class="d-flex align-items-center">
                            <span class="material-icons me-2">check_circle</span>
                            @TempData["SuccessMessage"]
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
                        <div class="d-flex align-items-center">
                            <span class="material-icons me-2">error</span>
                            @TempData["ErrorMessage"]
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    <!-- Login Layout -->
    <div class="login-page">
        <div class="login-box">
            @RenderBody()
        </div>
    </div>
}

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<!-- SignalR -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarClose = document.getElementById('sidebarClose');
        const sidebarOverlay = document.getElementById('sidebarOverlay');
        const body = document.body;
        
        // Funzione per gestire il toggle
        function toggleSidebar() {
            if (window.innerWidth >= 992) {
                // Desktop: Collapse
                body.classList.toggle('sidebar-collapsed');
                localStorage.setItem('sidebar-collapsed', body.classList.contains('sidebar-collapsed'));
            } else {
                // Mobile: Open/Close Overlay
                body.classList.toggle('sidebar-open');
            }
        }

        // Ripristina stato salvato (solo desktop)
        if (window.innerWidth >= 992) {
            const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
            if (isCollapsed) {
                body.classList.add('sidebar-collapsed');
            }
        }

        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', toggleSidebar);
        }

        if (sidebarClose) {
            sidebarClose.addEventListener('click', function() {
                body.classList.remove('sidebar-open');
            });
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', function() {
                body.classList.remove('sidebar-open');
            });
        }
        
        // Chiudi sidebar mobile al click su un link
        const navLinks = document.querySelectorAll('.sidebar .nav-link');
        navLinks.forEach(link => {
            link.addEventListener('click', function() {
                if (window.innerWidth < 992) {
                    body.classList.remove('sidebar-open');
                }
            });
        });
    });
</script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>