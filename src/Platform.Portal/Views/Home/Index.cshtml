@model List<Platform.Portal.Controllers.ApplicationInfo>

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Statistiche -->
<div class="row mb-4">
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-icon green">
                    <span class="material-icons">apps</span>
                </div>
                <div class="stat-info">
                    <h3>@(Model?.Count ?? 0)</h3>
                    <p>Applicazioni</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-icon blue">
                    <span class="material-icons">people</span>
                </div>
                <div class="stat-info">
                    <h3>--</h3>
                    <p>Utenti Attivi</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-icon orange">
                    <span class="material-icons">schedule</span>
                </div>
                <div class="stat-info">
                    <h3 id="currentTime">--:--</h3>
                    <p>Ora Sistema</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="stat-icon green">
                    <span class="material-icons">dns</span>
                </div>
                <div class="stat-info">
                    <h3>Online</h3>
                    <p>Stato Sistema</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-md-6">
            <div class="card stat-card">
                <div class="stat-icon green">
                    <span class="material-icons">waving_hand</span>
                </div>
                <div class="stat-info">
                    <h3>Ciao, @User.Identity?.Name</h3>
                    <p>Benvenuto nella tua dashboard</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card stat-card">
                <div class="stat-icon orange">
                    <span class="material-icons">calendar_today</span>
                </div>
                <div class="stat-info">
                    <h3>@DateTime.Now.ToString("dd MMMM yyyy")</h3>
                    <p>Data Odierna</p>
                </div>
            </div>
        </div>
    }
</div>

<!-- Applicazioni -->
<h4 class="mb-3 fw-bold text-secondary">Le tue Applicazioni</h4>

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var app in Model)
        {
            <div class="col-md-4 mb-4">
                @if (app.Url.StartsWith("/"))
                {
                    <a href="@app.Url" class="card app-card">
                        <div class="card-body text-center d-flex flex-column align-items-center h-100">
                            <div class="app-icon-container">
                                <span class="material-icons">@app.Icon</span>
                            </div>
                            <h5 class="app-title">@app.Name</h5>
                            <p class="app-desc">@app.Description</p>
                            <span class="btn btn-outline-secondary btn-sm mt-auto w-100">Apri</span>
                        </div>
                    </a>
                }
                else
                {
                    <a asp-controller="Apps" asp-action="View" asp-route-appId="@app.AppId" class="card app-card">
                        <div class="card-body text-center d-flex flex-column align-items-center h-100">
                            <div class="app-icon-container">
                                <span class="material-icons">@app.Icon</span>
                            </div>
                            <h5 class="app-title">@app.Name</h5>
                            <p class="app-desc">@app.Description</p>
                            <span class="btn btn-outline-secondary btn-sm mt-auto w-100">Apri</span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
}
else
{
    <div class="card p-5 text-center">
        <div class="mb-3 text-muted">
            <span class="material-icons" style="font-size: 48px;">inbox</span>
        </div>
        <h5>Nessuna applicazione disponibile</h5>
        <p class="text-muted">Non hai accesso a nessuna applicazione al momento.</p>
    </div>
}

@section Scripts {
    <script>
        function updateTime() {
            const now = new Date();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const timeEl = document.getElementById('currentTime');
            if(timeEl) timeEl.textContent = `${hours}:${minutes}`;
        }
        
        updateTime();
        setInterval(updateTime, 60000);
    </script>
}