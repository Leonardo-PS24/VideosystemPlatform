@model List<Platform.Portal.Models.CompanyInfo>

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Statistiche -->
<div class="row mb-4">
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-4">
            <div class="card stat-card">
                <div class="stat-icon primary">
                    <span class="material-icons">business</span>
                </div>
                <div class="stat-info">
                    <h3>@(Model?.Count ?? 0)</h3>
                    <p>Aziende Gestite</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card">
                <div class="stat-icon primary">
                    <span class="material-icons">schedule</span>
                </div>
                <div class="stat-info">
                    <h3 id="currentTime">--:--</h3>
                    <p>Ora Sistema</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card">
                <div class="stat-icon primary">
                    <span class="material-icons">dns</span>
                </div>
                <div class="stat-info">
                    <h3>Online</h3>
                    <p>Stato Sistema</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-md-6">
            <div class="card stat-card">
                <div class="stat-icon primary">
                    <span class="material-icons">waving_hand</span>
                </div>
                <div class="stat-info">
                    <h3>Ciao, @User.Identity?.Name</h3>
                    <p>Benvenuto nella tua dashboard</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card stat-card">
                <div class="stat-icon primary">
                    <span class="material-icons">calendar_today</span>
                </div>
                <div class="stat-info">
                    <h3>@DateTime.Now.ToString("dd MMMM yyyy")</h3>
                    <p>Data Odierna</p>
                </div>
            </div>
        </div>
    }
</div>

<!-- Aziende e Applicazioni -->
@if (Model != null && Model.Any())
{
    foreach (var company in Model)
    {
        <div class="card mb-4">
            <div class="card-header" style="background-color: @company.PrimaryColor; color: @company.SecondaryColor;">
                <h4 class="mb-0">@company.Name</h4>
            </div>
            <div class="card-body">
                @if (company.Applications != null && company.Applications.Any())
                {
                    <div class="row">
                        @foreach (var app in company.Applications)
                        {
                            <div class="col-md-4 mb-4">
                                <a href="@app.Url" class="card app-card">
                                    <div class="card-body text-center d-flex flex-column align-items-center h-100">
                                        <div class="app-icon-container" style="background-color: @(company.PrimaryColor + "1A"); color: @company.PrimaryColor;">
                                            <span class="material-icons">@app.Icon</span>
                                        </div>
                                        <h5 class="app-title">@app.Name</h5>
                                        <p class="app-desc">@app.Description</p>
                                        <span class="btn btn-sm mt-auto w-100" style="border-color: @company.PrimaryColor; color: @company.PrimaryColor;">Apri</span>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Nessuna applicazione disponibile per questa azienda.</p>
                }
            </div>
        </div>
    }
}
else
{
    <div class="card p-5 text-center">
        <div class="mb-3 text-muted">
            <span class="material-icons" style="font-size: 48px;">business</span>
        </div>
        <h5>Nessuna azienda configurata</h5>
        <p class="text-muted">Non sono state ancora configurate aziende nella piattaforma.</p>
    </div>
}

@section Scripts {
    <script>
        function updateTime() {
            const now = new Date();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const timeEl = document.getElementById('currentTime');
            if(timeEl) timeEl.textContent = `${hours}:${minutes}`;
        }
        
        updateTime();
        setInterval(updateTime, 60000);
    </script>
}
