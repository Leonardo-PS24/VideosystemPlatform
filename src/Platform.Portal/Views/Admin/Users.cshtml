@model List<UserListViewModel>

@{
    ViewData["Title"] = "Gestione Utenti";
}

@section HeaderActions {
    <a asp-action="CreateUser" class="btn btn-primary">
        <span class="material-icons">add</span>
        Nuovo Utente
    </a>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Utente</th>
                        <th>Email</th>
                        <th>Nome Completo</th>
                        <th>Ruolo</th>
                        <th>Stato</th>
                        <th class="text-end">Azioni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar" style="width: 32px; height: 32px; font-size: 0.9rem; min-width: 32px;">
                                        @user.Username.Substring(0, 1).ToUpper()
                                    </div>
                                    <span class="fw-bold">@user.Username</span>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>@user.FullName</td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary") rounded-pill">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill">Attivo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill">Disattivo</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary" title="Modifica">
                                        <span class="material-icons" style="font-size: 18px;">edit</span>
                                    </a>
                                    
                                    <form asp-action="ToggleUserStatus" asp-route-id="@user.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="@(user.IsActive ? "Disattiva" : "Attiva")">
                                            <span class="material-icons" style="font-size: 18px;">@(user.IsActive ? "block" : "check_circle")</span>
                                        </button>
                                    </form>
                                    
                                    @if (user.Username != User.Identity!.Name)
                                    {
                                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Sei sicuro di voler eliminare questo utente?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Elimina">
                                                <span class="material-icons" style="font-size: 18px;">delete</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>